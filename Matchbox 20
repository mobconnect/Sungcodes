import React, { useState } from "react";

export default function ThreeAM() {
  const [lyrics] = useState([
    "The night feels cold and heavy.",
    "Worry hangs in the air.",
    "Fear shows up in quiet moments.",
    "The rain feels like a backdrop for the mood.",
    "Loneliness becomes impossible to ignore."
  ]);

  return (
    <div>
      {lyrics.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

