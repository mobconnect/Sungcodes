Diamonds are a girls beat friend 
import React, { useState } from "react";

export default function DiamondsAreAGirlsBestFriend() {
  const [lyrics] = useState([
    "The song sparkles with glamour.",
    "The mood is playful and polished.",
    "Wealth and style sit at the center.",
    "The vibe is classic Hollywood.",
    "The energy feels iconic."
  ]);

  return (
    <div>
      {lyrics.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

