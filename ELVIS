Heartbreak Hotel
import React, { useState } from "react";

export default function HeartbreakHotel() {
  const [lines] = useState([
    "The mood is lonely and dramatic.",
    "The song feels like a warning sign.",
    "Heartache is the main character.",
    "The energy is classic rock and roll.",
    "The whole track sounds unforgettable."
  ]);

  return (
    <div>
      {lines.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

