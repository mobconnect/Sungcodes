  <title>Beat Timing Lyrics</title>
  <style>
    body {
      margin: 0;
      background: #111;
      color: #fff;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .player {
      width: 90vw;
      max-width: 700px;
    }
    .line {
      padding: 14px 18px;
      margin: 10px 0;
      border-radius: 10px;
      background: #222;
      opacity: 0.55;
      transition: 0.3s ease;
      text-align: center;
      font-size: 1.2rem;
    }
    .active {
      background: #ffd966;
      color: #111;
      opacity: 1;
      transform: scale(1.04);
      font-weight: bold;
    }
    button {
      padding: 10px 16px;
      margin: 0 8px 16px 0;
      border: none;
      border-radius: 8px;
      background: #ffd966;
      color: #111;
      font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="player">
    <button onclick="startKaraoke()">Start</button>
    <button onclick="stopKaraoke()">Stop</button>

    <div id="lyrics">
      <div class="line">Feel the rhythm. Feel the pride.</div>
      <div class="line">I left the old weight behind.</div>
      <div class="line">I got my groove back.</div>
      <div class="line">Built by my matriarchs.</div>
      <div class="line">No shame, no silence.</div>
      <div class="line">Proud, loud, and groovy.</div>
    </div>
  </div>

  <script>
    const lines = document.querySelectorAll(".line");
    const timing = [0, 2500, 5000, 7500, 10000, 12500];
    let timers = [];

    function clearAll() {
      timers.forEach(t => clearTimeout(t));
      timers = [];
      lines.forEach(line => line.classList.remove("active"));
    }

    function startKaraoke() {
      clearAll();
      lines.forEach((line, i) => {
        const t = setTimeout(() => {
          lines.forEach(l => l.classList.remove("active"));
          line.classList.add("active");
        }, timing[i]);
        timers.push(t);
      });
    }

    function stopKaraoke() {
      clearAll();
    }
  </script>
</body>
</html>

