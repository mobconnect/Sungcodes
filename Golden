function golden() {
  let state = {
    hidden: true,
    shining: false,
    fear: true,
    truth: false,
    together: false
  };

  const journey = [
    "was alone",
    "found a voice",
    "stopped hiding",
    "started shining",
    "became golden"
  ];

  for (let step of journey) {
    if (step === "was alone") state.hidden = true;
    if (step === "found a voice") state.fear = false;
    if (step === "stopped hiding") state.truth = true;
    if (step === "started shining") state.shining = true;
    if (step === "became golden") state.together = true;
  }

  if (state.truth && state.shining) {
    return "We're going up, up, up — gonna be golden.";
  }

  return "Still finding the light.";
}

