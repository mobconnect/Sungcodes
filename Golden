ccs frame work
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scrolling Lyric Animation</title>
  <style>
    body {
      margin: 0;
      background: #111;
      color: #fff;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .wrapper {
      width: 90vw;
      max-width: 600px;
    }

    .controls {
      margin-bottom: 12px;
      display: flex;
      gap: 10px;
    }

    button {
      padding: 10px 16px;
      border: none;
      border-radius: 8px;
      background: #ffd966;
      color: #111;
      font-weight: bold;
      cursor: pointer;
    }

    .scroll-box {
      height: 60vh;
      overflow: hidden;
      border: 2px solid #ffd966;
      border-radius: 12px;
      background: #000;
      position: relative;
    }

    .lyrics {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 24px;
      line-height: 1.8;
      font-size: 1.2rem;
      text-align: center;
      animation: scrollUp 30s linear infinite;
    }

    .paused {
      animation-play-state: paused;
    }

    @keyframes scrollUp {
      from { transform: translateY(0); }
      to { transform: translateY(-180%); }
    }

    .line {
      margin: 18px 0;
    }

    .highlight {
      color: #ffd966;
      font-size: 1.35rem;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="controls">
      <button onclick="togglePlay()">Play / Pause</button>
      <button onclick="restartScroll()">Restart</button>
    </div>

    <div class="scroll-box">
      <div id="lyrics" class="lyrics">
        <div class="line">[Verse 1] I was lost in the dark, trying to find my way.</div>
        <div class="line">[Pre-Chorus] Then something changed, and I stood my ground.</div>
        <div class="line highlight">[Chorus] We’re going up, up, up — this is our moment.</div>
        <div class="line">[Verse 2] The past can’t hold me now.</div>
        <div class="line">[Bridge] No more masks, no more lies.</div>
        <div class="line highlight">[Final Chorus] We were born to rise, we were born to shine.</div>
        <div class="line">[Outro] Born to be golden.</div>
      </div>
    </div>
  </div>

  <script>
    const lyrics = document.getElementById("lyrics");
    let isPaused = false;

    function togglePlay() {
      isPaused = !isPaused;
      lyrics.classList.toggle("paused", isPaused);
    }

    function restartScroll() {
      lyrics.classList.remove("paused");
      isPaused = false;
      lyrics.style.animation = "none";
      void lyrics.offsetWidth;
      lyrics.style.animation = "scrollUp 30s linear infinite";
    }
  </script>
</body>
</html>



