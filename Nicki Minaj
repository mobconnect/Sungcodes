super bass
import React, { useState } from "react";

export default function SuperBass() {
  const [lyrics] = useState([
    "The energy is playful and loud.",
    "Confidence drives every line.",
    "The rhythm stays bright and catchy.",
    "The mood is fun and bold.",
    "The whole track feels larger than life."
  ]);

  return (
    <div>
      {lyrics.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

