import React, { useState } from "react";
import styled from "styled-components";

const Card = styled.div`
  max-width: 640px;
  margin: 40px auto;
  padding: 24px;
  border-radius: 20px;
  background: linear-gradient(135deg, #ff7ac8, #8b5cf6);
  color: white;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
  font-family: Arial, sans-serif;
`;

const Title = styled.h2`
  margin: 0 0 16px;
  font-size: 28px;
  text-align: center;
`;

const Line = styled.p`
  margin: 10px 0;
  padding: 12px 14px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(6px);
  font-size: 16px;
  line-height: 1.5;
`;

export default function BarbieGirlChorus() {
  const [lines] = useState([
    "The world is shiny and artificial.",
    "The vibe is playful and exaggerated.",
    "Everything feels like a pop fantasy.",
    "The hook celebrates having fun.",
    "The chorus keeps inviting the party."
  ]);

  return (
    <Card>
      <Title>Barbie Girl Chorus</Title>
      {lines.map((line, index) => (
        <Line key={index}>{line}</Line>
      ))}
    </Card>
  );
}
