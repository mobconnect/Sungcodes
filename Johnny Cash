Folsom prison blues
import React, { useState } from "react";

export default function FolsomPrisonBlues() {
  const [lines] = useState([
    "The mood is gritty and confined.",
    "The train imagery keeps rolling through.",
    "The story feels cold and restless.",
    "The song carries a classic outlaw feel.",
    "The rhythm stays unforgettable."
  ]);

  return (
    <div>
      {lines.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

