import React, { useEffect, useState } from "react";

const lines = [
  { time: 0, text: "Calm before the storm." },
  { time: 4000, text: "Something monstrous is waking up." },
  { time: 8000, text: "The pressure builds." },
  { time: 12000, text: "The voice gets faster." },
  { time: 16000, text: "The verse starts to run wild." },
