  { time: 24000, text: "The final burst of speed lands." },
  { time: 28000, text: "The monster is fully unleashed." }
];

export default function GodzillaKaraoke() {
  const [currentLineIndex, setCurrentLineIndex] = useState(0);

  useEffect(() => {
    const audio = document.getElementById("audio");
    const interval = setInterval(() => {
      const t = audio?.currentTime ? audio.currentTime * 1000 : 0;
      let index = 0;
      for (let i = 0; i < lines.length; i++) {
        if (t >= lines[i].time) index = i;
      }
      setCurrentLineIndex(index);
    }, 100);

    return () => clearInterval(interval);
  }, []);

  return (
    <div style={{ padding: 24, background: "#111", color: "#fff" }}>
      <audio id="audio" controls src="/godzilla.mp3" />
      <div style={{ marginTop: 24, maxHeight: "60vh", overflowY: "auto" }}>
        {lines.map((line, i) => (
          <div
            key={i}
            style={{
              padding: "12px 16px",
              margin: "8px 0",
              borderRadius: 10,
              textAlign: "center",
              background: i === currentLineIndex ? "#7df9ff" : "#222",
              color: i === currentLineIndex ? "#111" : "#fff",
              fontWeight: i === currentLineIndex ? 700 : 400,
              transition: "all 0.2s ease"
            }}
          >
            {line.text}
          </div>
        ))}
      </div>
    </div>
  );
}

