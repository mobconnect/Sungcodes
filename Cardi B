React
import React, { useEffect, useRef } from "react";

export default function DramaTracks({ tracks = [], currentIndex = 0 }) {
  const refs = useRef([]);

  useEffect(() => {
    const el = refs.current[currentIndex];
    if (el) el.scrollIntoView({ behavior: "smooth", block: "center" });
  }, [currentIndex]);

  return (
    <div style={{
      height: "70vh",
      overflowY: "auto",
      padding: 24,
      background: "#0b0b0b",
      borderRadius: 16,
      border: "1px solid #333"
    }}>
      {tracks.map((item, i) => {
        const active = i === currentIndex;
        return (
          <div
            key={i}
            ref={(el) => (refs.current[i] = el)}
            style={{
              padding: "12px 16px",
              margin: "8px 0",
              borderRadius: 10,
              textAlign: "center",
              background: active ? "#ff4d8d" : "transparent",
              color: active ? "#111" : "#fff",
              fontWeight: active ? 700 : 400,
              opacity: active ? 1 : 0.65
            }}
          >
            {item.track} — {item.theme}
          </div>
        );
      })}
    </div>
  );
}


