Save me
import React, { useState } from "react";

export default function SaveMe() {
  const [lyrics] = useState([
    "The song is raw and exposed.",
    "Pain and regret sit at the center.",
    "The voice feels desperate but honest.",
    "The mood is heavy and emotional.",
    "The plea for help is unmistakable."
  ]);

  return (
    <div>
      {lyrics.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

