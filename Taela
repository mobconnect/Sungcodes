Watch this
import React, { useState } from "react";

export default function WatchThis() {
  const [lyrics] = useState([
    "The energy is loud and rebellious.",
    "The mood feels like a warning shot.",
    "Confidence leads the whole track.",
    "The vibe is sharp and fearless.",
    "The song comes in with attitude."
  ]);

  return (
    <div>
      {lyrics.map((line, index) => (
        <p key={index}>{line}</p>
      ))}
    </div>
  );
}

