example usage
import React, { useEffect, useState } from "react";
import LyricsViewer from "./LyricsViewer";

const lines = [
  "I knew you in the light of childhood wonder.",
  "Time moved on, but the bond stayed close.",
  "I knew it, I knew you.",
  "Growing up does not mean letting go.",
  "Some stories stay with us forever."
];

export default function App() {
  const [currentLineIndex, setCurrentLineIndex] = useState(0);

  useEffect(() => {
    const timer = setInterval(() => {
      setCurrentLineIndex((i) => (i + 1) % lines.length);
    }, 2500);

    return () => clearInterval(timer);
  }, []);

  return (
    <div style={{ padding: 24, background: "#111", minHeight: "100vh" }}>
      <LyricsViewer lines={lines} currentLineIndex={currentLineIndex} />
    </div>
  );
}

